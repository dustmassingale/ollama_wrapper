# Ollama Proxy Server -- environment configuration
# Copy this file to .env and fill in your values.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your credentials, then:
#   pip install -r requirements.txt
#   python proxy.py
#
# Model prefixes used by the proxy:
#   GH |   GitHub Models via Azure AI Inference  (PAT-backed, free quota)
#   GC |   GitHub Copilot Chat                   (OAuth device-flow, Copilot subscription)
#   BR |   AWS Bedrock                           (pay-per-use, fill-in-the-gap)
#   155 |  Remote Ollama server at REMOTE_OLLAMA_URL

# ---------------------------------------------------------------------------
# GitHub Models  -- required for GH | models
# ---------------------------------------------------------------------------
# A standard GitHub Personal Access Token (classic or fine-grained).
# No special scopes are required -- a zero-scope classic token is sufficient.
# Create one at: https://github.com/settings/tokens
#
# Gives access to models listed at:
#   https://models.inference.ai.azure.com/models
# Currently includes:
#   Chat  : gpt-4o, gpt-4o-mini, Meta-Llama-3.1-405B, Meta-Llama-3.1-8B,
#           Mistral-Nemo, Mistral-Large, AI21-Jamba-Instruct
#   Embed : Cohere-embed-v3-english, Cohere-embed-v3-multilingual,
#           text-embedding-3-large, text-embedding-3-small
GITHUB_TOKEN=github_pat_your_token_here

# ---------------------------------------------------------------------------
# GitHub Copilot Chat  -- optional, enables GC | models
# ---------------------------------------------------------------------------
# OAuth token obtained automatically via the device-flow login built into
# the proxy.  Do NOT set this by hand -- let the proxy fill it in:
#
#   1. Start the proxy:           python proxy.py
#   2. Open in your browser:      http://localhost:5000/auth/copilot
#   3. Enter the displayed code at https://github.com/login/device
#   4. Check status at:           http://localhost:5000/auth/status
#
# The proxy writes the token here automatically once login succeeds.
# It will be refreshed on the next successful device-flow login.
#
# Requires an active GitHub Copilot Individual or Business subscription.
# Gives access to: Claude Sonnet/Haiku/Opus, GPT-4o, GPT-4.1, Gemini,
#                  Grok, Llama, and more (account entitlements vary).
GITHUB_TOKEN_COPILOT=

# ---------------------------------------------------------------------------
# AWS Bedrock  -- optional, enables BR | models
# ---------------------------------------------------------------------------
# IAM user access key with permission to invoke Bedrock foundation models.
#
# Minimum IAM policy to attach to the IAM user:
#
#   {
#     "Version": "2012-10-17",
#     "Statement": [
#       {
#         "Sid": "BedrockInvokeAccess",
#         "Effect": "Allow",
#         "Action": [
#           "bedrock:InvokeModel",
#           "bedrock:InvokeModelWithResponseStream"
#         ],
#         "Resource": "arn:aws:bedrock:*::foundation-model/*"
#       }
#     ]
#   }
#
# Steps to create credentials:
#   1. Go to https://console.aws.amazon.com/iam/home#/users
#   2. Create a user (or select an existing one)
#   3. Attach the policy above
#   4. Open the user > Security credentials > Create access key
#   5. Choose "Application running outside AWS"
#   6. Copy the Access Key ID and Secret Access Key shown (only shown once)
#
# IMPORTANT: never commit real credentials to source control.
# The proxy only advertises Bedrock models that are NOT already available
# for free via GH | or GC |, following a free-before-paid strategy.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# AWS region where you have Bedrock model access enabled.
# Model availability varies by region.  Reference:
#   https://docs.aws.amazon.com/bedrock/latest/userguide/models-regions.html
#
# Recommended regions (broadest model selection as of 2025):
#   us-east-1        -- US East (N. Virginia)   <-- widest selection
#   us-west-2        -- US West (Oregon)
#   eu-west-1        -- Europe (Ireland)
#   ap-southeast-1   -- Asia Pacific (Singapore)
#
# Before models will work you must explicitly enable each one in the console:
#   https://console.aws.amazon.com/bedrock/home#/modelaccess
#
# Models the proxy will advertise under BR | (if not already in GH/GC):
#   Chat  : Claude Haiku 3/3.5/4, Mistral Large/Small, Mixtral 8x7B,
#           Llama 3.3 70B, Llama 3.1 405B/70B/8B, Llama 3 8B
#   Embed : Amazon Titan Embed Text v1 and v2
AWS_BEDROCK_REGION=us-east-1

# ---------------------------------------------------------------------------
# Remote Ollama server  -- models appear with the "155 | " prefix
# ---------------------------------------------------------------------------
# URL of the Ollama instance to proxy.
# Change the IP and port to match your setup.
REMOTE_OLLAMA_URL=http://192.168.1.155:11434

# ---------------------------------------------------------------------------
# Proxy server
# ---------------------------------------------------------------------------
# TCP port the proxy listens on (default: 5000).
# Access locally:   http://localhost:PORT
# Access on LAN:    http://<your-machine-ip>:PORT
PORT=5000

# ---------------------------------------------------------------------------
# SSL certificate verification
# ---------------------------------------------------------------------------
# Set to "true" to disable SSL certificate verification.
#
# ⚠️  WARNING: Do NOT enable this in a production environment.
#     This is intended ONLY as a temporary workaround for corporate / enterprise
#     networks that inject a self-signed certificate into the TLS chain, causing
#     "self signed certificate in certificate chain" errors.
#     Use this only for local testing or while a proper CA-bundle fix is arranged
#     (e.g. setting REQUESTS_CA_BUNDLE to your corporate root certificate).
#
# DISABLE_SSL_VERIFY=true
