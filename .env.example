# Ollama Proxy Server — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# GitHub Models — Standard PAT  (required for GH | models)
# ---------------------------------------------------------------------------
# A regular GitHub Personal Access Token.
# No special scopes required — a zero-scope token works fine.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_your_token_here

# ---------------------------------------------------------------------------
# GitHub Copilot Token  (optional — required for GC | models)
# ---------------------------------------------------------------------------
# A GitHub PAT tied to a Copilot Pro / Business / Enterprise subscription.
# Unlocks Claude, Gemini, Grok, and other Copilot-tier models.
# Without this, GC | models are hidden from the model list entirely.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN_COPILOT=github_pat_your_copilot_token_here

# ---------------------------------------------------------------------------
# Remote Ollama server  (models appear with the "155 | " prefix)
# ---------------------------------------------------------------------------
REMOTE_OLLAMA_URL=http://192.168.1.155:11434

# ---------------------------------------------------------------------------
# Proxy server
# ---------------------------------------------------------------------------
# Port the proxy listens on (default: 5000)
PORT=5000
