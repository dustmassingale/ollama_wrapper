# Ollama Proxy Server — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# GitHub Models  (required for GH | models)
# ---------------------------------------------------------------------------
# A standard GitHub Personal Access Token.
# No special scopes required — a zero-scope classic token works fine.
# Create one at: https://github.com/settings/tokens
#
# Note: Claude, Gemini, Grok etc. are only available via the GitHub Copilot
# Chat OAuth flow (used by VS Code / Zed extensions) and cannot be accessed
# with a PAT. Only the models returned by:
#   GET https://models.inference.ai.azure.com/models
# are available through this proxy.
GITHUB_TOKEN=github_pat_your_token_here

# ---------------------------------------------------------------------------
# Remote Ollama server  (models appear with the "155 | " prefix)
# ---------------------------------------------------------------------------
REMOTE_OLLAMA_URL=http://192.168.1.155:11434

# ---------------------------------------------------------------------------
# Proxy server
# ---------------------------------------------------------------------------
# Port the proxy listens on (default: 5000)
PORT=5000
