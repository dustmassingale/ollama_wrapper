# RAG Agent — Environment Example
# Copy this file to .env and edit values before running the service.
#   cp .env.example .env
#   (or on Windows) copy .env.example .env
#
# This service is local-first and intended to call an existing model proxy
# (for example, the proxy implemented in the ollama_wrapper project).
#
# WARNING: Do NOT commit real secrets or tokens to source control.
# Use environment variables or a secrets manager for production.

# ---------------------------------------------------------------------------
# Agent & Proxy configuration
# ---------------------------------------------------------------------------
# URL of the upstream model proxy this agent will call.
# Examples:
# - Local proxy:    http://127.0.0.1:5000/v1
# - Remote proxy:   https://proxy.example.com/v1
LOCAL_PROXY_BASE=http://127.0.0.1:5000/v1

# If true, disable SSL certificate verification for requests to the proxy.
# Useful only for local testing when the proxy uses self-signed certs.
# WARNING: disabling SSL verification is insecure. Do not enable in production.
DISABLE_SSL_VERIFY=false

# Default models (names passed to the upstream proxy)
# Change these to models available through your proxy.
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Service runtime
# ---------------------------------------------------------------------------
# Host and port the agent service listens on.
# Use 127.0.0.1 if you want it accessible only locally.
AGENT_HOST=127.0.0.1
AGENT_PORT=7860

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Indexing and retrieval (MVP defaults)
# ---------------------------------------------------------------------------
# Backend for document store and vector search:
# - memory (default, ephemeral in-memory store)
# - chroma  (requires chromadb & configuration)
# - faiss   (requires faiss-cpu build)
# - hnswlib (requires hnswlib)
STORE_BACKEND=memory

# If using a persistent vector DB or database, configure its connection here.
# Example for a local Chroma (adjust according to your setup):
# CHROMA_PATH=./data/chroma
CHROMA_PATH=

# Indexing behavior
# If true, a file-save watcher will attempt to auto-index changed files.
AUTO_INDEX_ON_SAVE=false
INDEX_BATCH_SIZE=32

# How many documents to retrieve by default for RAG prompts
DEFAULT_TOP_K=5

# Limit snippet sizes when including retrieved docs in prompts (chars)
MAX_SNIPPET_CHARS=1500

# ---------------------------------------------------------------------------
# Security / access control
# ---------------------------------------------------------------------------
# Optional local API token to protect the agent service from unwanted access.
# If set, the Zed extension or any client must include:
#   Authorization: Bearer <AGENT_API_TOKEN>
# Leave blank to disable token check (NOT recommended if you expose beyond localhost).
AGENT_API_TOKEN=

# ---------------------------------------------------------------------------
# Memory & persistence
# ---------------------------------------------------------------------------
# Path to a JSON file used as a small "memory" seed the agent can consult.
# The repo includes a sample memory.json to start with.
MEMORY_FILE=./memory.json

# Optional persistence path for indexed docs when using non-memory backends
PERSISTENCE_PATH=./data/store

# ---------------------------------------------------------------------------
# Advanced / tuning
# ---------------------------------------------------------------------------
# Maximum tokens to request for completions (upstream may override)
MAX_TOKENS=1024

# Whether to stream assistant responses (SSE/websocket) — feature work in progress.
ENABLE_STREAMING=false

# ---------------------------------------------------------------------------
# Examples / helper notes
# ---------------------------------------------------------------------------
# Example for setting environment vars when running locally:
#   export LOCAL_PROXY_BASE=http://127.0.0.1:5000/v1
#   export CHAT_MODEL=claude-sonnet-4.6
#   uvicorn zed_agent_service:app --reload --port 7860
#
# On Windows (PowerShell):
#   $env:LOCAL_PROXY_BASE = "http://127.0.0.1:5000/v1"
#   $env:CHAT_MODEL = "claude-sonnet-4.6"
#
# When you use DISABLE_SSL_VERIFY=true you may also want to set
# REQUESTS_CA_BUNDLE to a corporate CA bundle instead of disabling verification:
#   export REQUESTS_CA_BUNDLE=/path/to/corp_root.pem
#
# ---------------------------------------------------------------------------
# End of file
# ---------------------------------------------------------------------------
